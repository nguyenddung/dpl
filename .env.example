APP_NAME=CócStudy
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-32-char-string-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

DATABASE_URL=postgresql+asyncpg://cocstudy:password@localhost:5432/cocstudy_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

UPLOAD_DIR=./uploads
MAX_AVATAR_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

AI_CACHE_TTL=3600
KNN_NEIGHBORS=20
MIN_SIMILARITY_THRESHOLD=0.40

RATE_LIMIT_PER_MINUTE=60

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/api/v1
